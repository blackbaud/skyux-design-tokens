{
  "theme": {
    "border": {
      "container": {
        "default": {
          "$type": "border",
          "$value": "var(--sky-border-width-container-base) var(--sky-border-style-divider) var(--sky-color-border-container-base)"
        }
      },
      "divider": {
        "default": {
          "$type": "border",
          "$value": "var(--sky-border-width-divider) var(--sky-border-style-divider) var(--sky-color-border-divider)"
        },
        "soft": {
          "$type": "border",
          "$value": "var(--sky-border-width-separator-row) var(--sky-border-style-separator-row) var(--sky-color-border-separator-row)"
        }
      },
      "danger": {
        "$type": "border",
        "$value": "var(--sky-border-width-container-base) var(--sky-border-style-divider) var(--sky-color-border-danger)"
      },
      "info": {
        "$type": "border",
        "$value": "var(--sky-border-width-container-base) var(--sky-border-style-divider) var(--sky-color-border-info)"
      },
      "success": {
        "$type": "border",
        "$value": "var(--sky-border-width-container-base) var(--sky-border-style-divider) var(--sky-color-border-success)"
      },
      "warning": {
        "$type": "border",
        "$value": "var(--sky-border-width-container-base) var(--sky-border-style-divider) var(--sky-color-border-warning)"
      },
      "width": {
        "container": {
          "default": {
            "$type": "borderWidth",
            "$value": "{border.width.container.base}"
          }
        },
        "divider": {
          "default": {
            "$type": "borderWidth",
            "$value": "{border.width.divider}"
          },
          "soft": {
            "$type": "borderWidth",
            "$value": "{border.width.separator.row}"
          }
        },
        "emphasized": {
          "$type": "borderWidth",
          "$value": "{border.width.emphasized}"
        },
        "accent": {
          "$type": "borderWidth",
          "$value": "{border.width.accent}"
        }
      },
      "style": {
        "divider": {
          "default": {
            "$type": "other",
            "$value": "{border.style.divider}"
          },
          "soft": {
            "$type": "other",
            "$value": "{border.style.separator.row}"
          }
        },
        "accent": {
          "$type": "other",
          "$value": "{border.style.accent}"
        }
      },
      "radius": {
        "xs": {
          "$type": "borderRadius",
          "$value": "{border.radius.xs}"
        },
        "s": {
          "$type": "borderRadius",
          "$value": "{border.radius.s}"
        },
        "m": {
          "$type": "borderRadius",
          "$value": "{border.radius.m}"
        },
        "pill": {
          "$type": "borderRadius",
          "$value": "{border.radius.pill}"
        },
        "round": {
          "$type": "borderRadius",
          "$value": "{border.radius.round}"
        }
      }
    }
  }
}