{
  "theme": {
    "border": {
      "container": {
        "default": {
          "$type": "border",
          "$value": "var(--sky-border-width-container-default) var(--sky-border-style-divider-default) var(--sky-color-border-container-default)"
        }
      },
      "divider": {
        "default": {
          "$type": "border",
          "$value": "var(--sky-border-width-divider-default) var(--sky-border-style-divider-default) var(--sky-color-border-divider-default)"
        },
        "soft": {
          "$type": "border",
          "$value": "var(--sky-border-width-divider-soft) var(--sky-border-style-divider-soft) var(--sky-color-border-divider-soft)"
        }
      },
      "danger": {
        "$type": "border",
        "$value": "var(--sky-border-width-container-default) var(--sky-border-style-divider-default) var(--sky-color-border-danger)"
      },
      "info": {
        "$type": "border",
        "$value": "var(--sky-border-width-container-default) var(--sky-border-style-divider-default) var(--sky-color-border-info)"
      },
      "success": {
        "$type": "border",
        "$value": "var(--sky-border-width-container-default) var(--sky-border-style-divider-default) var(--sky-color-border-success)"
      },
      "warning": {
        "$type": "border",
        "$value": "var(--sky-border-width-container-default) var(--sky-border-style-divider-default) var(--sky-color-border-warning)"
      },
      "width": {
        "container": {
          "default": {
            "$type": "borderWidth",
            "$value": "{border.width.container.default}"
          }
        },
        "divider": {
          "default": {
            "$type": "borderWidth",
            "$value": "{border.width.divider.default}"
          },
          "soft": {
            "$type": "borderWidth",
            "$value": "{border.width.divider.soft}"
          }
        },
        "emphasized": {
          "$type": "borderWidth",
          "$value": "{border.width.emphasized}"
        },
        "accent": {
          "$type": "borderWidth",
          "$value": "{border.width.accent}"
        }
      },
      "style": {
        "divider": {
          "default": {
            "$type": "other",
            "$value": "{border.style.divider.default}"
          },
          "soft": {
            "$type": "other",
            "$value": "{border.style.divider.soft}"
          }
        },
        "accent": {
          "$type": "other",
          "$value": "{border.style.accent}"
        }
      },
      "radius": {
        "xs": {
          "$type": "borderRadius",
          "$value": "{border.radius.xs}"
        },
        "s": {
          "$type": "borderRadius",
          "$value": "{border.radius.s}"
        },
        "m": {
          "$type": "borderRadius",
          "$value": "{border.radius.m}"
        },
        "pill": {
          "$type": "borderRadius",
          "$value": "{border.radius.pill}"
        },
        "round": {
          "$type": "borderRadius",
          "$value": "{border.radius.round}"
        }
      }
    }
  }
}