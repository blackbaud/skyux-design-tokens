{
  "theme": {
    "space": {
      "stacked": {
        "xs": {
          "$type": "spacing",
          "$value": "{space.stacked.xs}"
        },
        "s": {
          "$type": "spacing",
          "$value": "{space.stacked.s}"
        },
        "m": {
          "$type": "spacing",
          "$value": "{space.stacked.m}"
        },
        "l": {
          "$type": "spacing",
          "$value": "{space.stacked.l}"
        },
        "xl": {
          "$type": "spacing",
          "$value": "{space.stacked.xl}"
        },
        "xxl": {
          "$type": "spacing",
          "$value": "{space.stacked.xxl}"
        }
      },
      "inline": {
        "xs": {
          "$type": "spacing",
          "$value": "{space.inline.xs}"
        },
        "s": {
          "$type": "spacing",
          "$value": "{space.inline.s}"
        },
        "m": {
          "$type": "spacing",
          "$value": "{space.inline.m}"
        },
        "l": {
          "$type": "spacing",
          "$value": "{space.inline.l}"
        },
        "xl": {
          "$type": "spacing",
          "$value": "{space.inline.xl}"
        },
        "xxl": {
          "$type": "spacing",
          "$value": "{space.inline.xxl}"
        }
      },
      "inset": {
        "balanced": {
          "xs": {
            "$type": "spacing",
            "$value": "{space.inset.balanced.xs}"
          },
          "s": {
            "$type": "spacing",
            "$value": "{space.inset.balanced.s}"
          },
          "m": {
            "$type": "spacing",
            "$value": "{space.inset.balanced.m}"
          },
          "l": {
            "$type": "spacing",
            "$value": "{space.inset.balanced.l}"
          },
          "xl": {
            "$type": "spacing",
            "$value": "{space.inset.balanced.xl}"
          }
        }
      },
      "conditional": {
        "input": {
          "$type": "spacing",
          "$value": "{space.inset.switch}"
        }
      }
    }
  }
}
