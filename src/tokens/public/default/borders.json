{
  "theme": {
    "border": {
      "container": {
        "default": { "$value": "1px solid #cdcfd2", "$type": "border" }
      },
      "divider": {
        "default": { "$value": "1px solid #cdcfd2", "$type": "border" },
        "soft": { "$value": "1px solid #cdcfd2", "$type": "border" }
      },
      "danger": { "$value": "1px solid #ef4044", "$type": "border" },
      "info": { "$value": "1px solid #00b4f1", "$type": "border" },
      "success": { "$value": "1px solid #72bf44", "$type": "border" },
      "warning": { "$value": "1px solid #fbb034", "$type": "border" },
      "width": {
        "container": {
          "default": { "$value": "1px", "$type": "border" }
        },
        "divider": {
          "default": { "$value": "1px", "$type": "border" },
          "soft": { "$value": "1px", "$type": "border" }
        },
        "emphasized": { "$value": "2px", "$type": "border" },
        "accent": { "$value": "4px", "$type": "border" }
      },
      "style": {
        "divider": {
          "default": { "$value": "solid", "$type": "border" },
          "soft": { "$value": "solid", "$type": "border" }
        },
        "accent": { "$value": "solid", "$type": "border" }
      },
      "radius": {
        "xs": { "$value": "4px", "$type": "border" },
        "s": { "$value": "4px", "$type": "border" },
        "m": { "$value": "4px", "$type": "border" },
        "pill": { "$value": "1000px", "$type": "border" },
        "round": { "$value": "50%", "$type": "border" }
      }
    }
  }
}
