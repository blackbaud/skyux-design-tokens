        {
          "name": "Containers",
          "description": "A border that wraps around a container and separates it from its surroundings.",
          "styles": [
            {
              "name": "Container base",
              "className": "sky-theme-border-container-base",
              "properties": {
                "border": "var(--sky-theme-border-container-base)"
              }
            }
          ]
        },
        {
